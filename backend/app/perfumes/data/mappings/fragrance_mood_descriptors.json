    },
    {
      "family": "오리엔탈",
      "sub": "우디 앰버",
      "notes": "샌달우드, 파출리와 더불어 향신료와 부드러운 꽃을 곁들인 로즈우드의 감각적인 향"
    },
    {
      "family": "우디",
      "sub": "우디",
      "notes": "파출리, 삼나무, 소나무, 샌달우드, 베티버와 같은 대담하고 전통적인 나무향"
    },
    {
      "family": "우디",
      "sub": "모시 우디",
      "notes": "그린노트 혹은 시트러스가 가미된 오크이끼와 흙냄새"
    },
    {
      "family": "우디",
      "sub": "드라이 우디",
      "notes": "가죽, 담배, 삼나무의 스모키하고 따뜻한 향"
    },
    {
      "family": "프레시",
      "sub": "아로마틱",
      "notes": "라벤더와 로즈마리, 바질과 다른 허브의 조합에 나무의 향이 어우러진 깨끗하고 단순하며 가벼운 향"
    },
    {
      "family": "프레시",
      "sub": "시트러스",
      "notes": "레몬, 만다린, 오렌지, 베르가못 등 귤속 과일의 상쾌하고 가벼운 향"
    },
    {
      "family": "프레시",
      "sub": "워터",
      "notes": "워터리, 마린, 오조닉 노트를 표현한 향료를 사용하며 바닷가의 비릿하고 시원한 향"
    },
    {
      "family": "프레시",
      "sub": "그린",
      "notes": "녹차 잎, 허브등 초록빛을 연상시키는 청정한 느낌의 향"
    },
    {
      "family": "구르망",
      "sub": "프루티",
      "notes": "달콤하고 과육이 많은 열대과일, 복숭아, 베리, 사과등 입맛을 돋우는 향"
    },
    {
      "family": "구르망",
      "sub": "구르망",
      "notes": "바닐라, 카라멜, 초콜릿, 꿀과 같이 먹고 싶어지는 달콤하고 풍부한 디저트 향"
    }
