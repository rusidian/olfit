# Olfít Connect: Environment Variables Template
# 이 파일을 .env로 복사하여 실제 값을 입력하세요.

# [Project Settings]
TZ=Asia/Seoul
LOG_MAX_SIZE=10MB
LOG_MAX_FILE=5

# [Database Resources]
DATABASE_CPUS=1
DATABASE_MEMORY_LIMIT=512MB
DATABASE_MEMORY_RESERVATION=128MB
DATABASE_PIDS_LIMIT=100
DATABASE_NOFILE_SOFT=1024
DATABASE_NOFILE_HARD=2048

# [MySQL Configuration]
# 중요: 실제 배포 시 비밀번호를 반드시 변경하세요.
MYSQL_ROOT_PASSWORD=your_root_password
MYSQL_INITDB_SKIP_TZINFO=1

# [SQL Database (Default)]
SQL_DB_HOST=database
SQL_DB_PORT=3306
SQL_DB_NAME=olfit_db
SQL_TEST_DB_NAME=test_olfit_db
SQL_DB_USER=olfit_admin
SQL_DB_PASSWORD=your_db_password

# [Backend Resources]
BACKEND_CPUS=1
BACKEND_MEMORY_LIMIT=512MB
BACKEND_MEMORY_RESERVATION=128MB
BACKEND_PIDS_LIMIT=100
BACKEND_NOFILE_SOFT=1024
BACKEND_NOFILE_HARD=2048
BACKEND_PORT=8000

# [Frontend Resources]
FRONTEND_CPUS=1
FRONTEND_MEMORY_LIMIT=512MB
FRONTEND_MEMORY_RESERVATION=128MB
FRONTEND_PIDS_LIMIT=100
FRONTEND_NOFILE_SOFT=1024
FRONTEND_NOFILE_HARD=2048
FRONTEND_PORT=3000
VITE_API_URL=http://localhost:8000

# [AI Model APIs]
# NVIDIA NIM API Key (Gemma VLM 전용)
NVIDIA_API_KEY=your_nvidia_api_key_here

# OpenRouter API Key (Gemini 등 기타 모델 사용 시)
OPENROUTER_API_KEY=your_openrouter_api_key_here
